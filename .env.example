# Copy this file to .env and fill in only the providers you want to use.

# Provider routing: openai, anthropic, or google.
WIRELESS_TAXONOMY_LLM_PROVIDER=openai
WIRELESS_TAXONOMY_LLM_FALLBACKS=anthropic,google

# Default model choices. Override these if provider API IDs change.
WIRELESS_TAXONOMY_OPENAI_MODEL=gpt-5.4-mini
WIRELESS_TAXONOMY_ANTHROPIC_MODEL=claude-sonnet-4-6
WIRELESS_TAXONOMY_GOOGLE_MODEL=gemini-3.5-flash

# Optional LLM request bounds.
WIRELESS_TAXONOMY_LLM_MAX_TOKENS=16000
WIRELESS_TAXONOMY_LLM_TIMEOUT_SECONDS=120

# Optional evidence log override. Defaults near the selected SQLite DB.
# WIRELESS_TAXONOMY_EVIDENCE_DIR=evidence

# Fetch/resolver credentials. Semantic Scholar is strongly recommended for
# DOI/title -> open-access PDF discovery. Unpaywall requires an email, not a key.
SEMANTIC_SCHOLAR_API_KEY=
# S2_API_KEY is also accepted if SEMANTIC_SCHOLAR_API_KEY is unset.
S2_API_KEY=
WIRELESS_TAXONOMY_UNPAYWALL_EMAIL=
# UNPAYWALL_EMAIL is also accepted if WIRELESS_TAXONOMY_UNPAYWALL_EMAIL is unset.
UNPAYWALL_EMAIL=

# LLM API keys. Leave blank for providers you do not use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# GOOGLE_API_KEY is also accepted for Google if GEMINI_API_KEY is unset.
GOOGLE_API_KEY=
