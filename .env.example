# Copy this file to .env and fill in only the providers you want to use.

# Provider routing: openai, anthropic, or google.
WIRELESS_TAXONOMY_LLM_PROVIDER=openai
WIRELESS_TAXONOMY_LLM_FALLBACKS=anthropic,google

# Default model choices. Override these if provider API IDs change.
WIRELESS_TAXONOMY_OPENAI_MODEL=gpt-5.4-mini
WIRELESS_TAXONOMY_ANTHROPIC_MODEL=claude-sonnet-4-6
WIRELESS_TAXONOMY_GOOGLE_MODEL=gemini-3-flash-preview

# Embeddings are currently OpenAI-oriented in the skeleton.
WIRELESS_TAXONOMY_EMBEDDING_PROVIDER=openai
WIRELESS_TAXONOMY_EMBEDDING_MODEL=text-embedding-3-small

# Optional bounded web search for unresolved dataset evidence.
WIRELESS_TAXONOMY_ENABLE_WEB_SEARCH=0

# Optional evidence log override. Defaults near the selected SQLite DB.
# WIRELESS_TAXONOMY_EVIDENCE_DIR=evidence

# API keys. Leave blank for providers you do not use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# GOOGLE_API_KEY is also accepted for Google if GEMINI_API_KEY is unset.
GOOGLE_API_KEY=
